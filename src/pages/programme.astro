---
import Layout from "../layouts/Layout.astro";
import Download from "../components/commonsElements/Download.svelte";
import "../styles/global.css";
import programmeData from "../data/programme.json";

const sections = programmeData.document.sections;
---

<Layout title="Programme - MCCP">
  <main>
    <section class="hero-section program-hero">
      <div class="hero-content">
        <h1>Le programme</h1>
      </div>
    </section>

    <div class="content-wrapper">
      <!-- Téléchargement du programme -->
      <section class="download-section">
        <div class="document-card">
          <div class="document-icon">📋</div>
          <div class="document-info">
            <h3>Programme complet</h3>
            <p>Téléchargez le programme complet de la liste citoyenne du MCCP.</p>
            <Download 
              url="/assets/datas/programme/Programme-mccp-2026.pdf"
              label="Télécharger le programme"
              format="PDF"
              inverted={true}
            />
          </div>
        </div>
      </section>

      <!-- Introduction au programme -->
      <section class="program-intro">
        <h2>MCCP Un programme construit avec les habitants</h2>
        <p>
          Ce programme s'inspire directement des <strong>10 réunions publiques</strong> organisées par le MCCP de juin 2025 à janvier 2026 dans toutes les communes déléguées de Putanges-le-Lac. Les propositions et objectifs présentés ci-dessous sont issus des échanges avec les habitants.
        </p>
      </section>

      <!-- Synthèse des réunions publiques -->
      <section class="synthesis-section">
        <div class="synthesis-card">
          <div class="synthesis-icon">📄</div>
          <div class="synthesis-content">
            <h3>Synthèse des réunions publiques</h3>
            <p>
              Retrouvez le compte rendu détaillé des 10 réunions publiques qui ont servi de base à l'élaboration de ce programme.
            </p>
            <Download 
              url="/assets/datas/programme/Synthese-des-reu-publique-2pages.pdf"
              label="Télécharger la synthèse"
              format="PDF"
              inverted={false}
            />
          </div>
        </div>
      </section>

      <!-- Les sections du programme -->
      <section class="program-sections">
        {sections.map((section, index) => {
          // Couleurs du dégradé du logo
          const colors = [
            { bg: '#1b365d', accent: '#1b365d' },
            { bg: '#2e8b57', accent: '#2e8b57' },
            { bg: '#3aa86f', accent: '#3aa86f' },
            { bg: '#66ba88', accent: '#66ba88' },
            { bg: '#b5985f', accent: '#b5985f' },
            { bg: '#d17c42', accent: '#d17c42' },
          ];
          const colorSet = colors[index % colors.length];
          
          return (
            <div class="program-section">
              <div class="section-number" style={`background: ${colorSet.bg};`}>
                {index + 1}
              </div>
              
              <h2 class="section-title" style={`color: ${colorSet.accent};`}>
                {section.theme}
              </h2>
              
              {/* Citations */}
              {section.quotes && section.quotes.length > 0 && (
                <div class="quotes-container">
                  {section.quotes.map((quote) => (
                    <blockquote class="program-quote" style={`border-left-color: ${colorSet.accent};`}>
                      {quote}
                    </blockquote>
                  ))}
                </div>
              )}

              {/* Un seul objectif */}
              {section.objective && typeof section.objective === 'string' && (
                <div class="objective-box" style={`background: ${colorSet.bg};`}>
                  <h3>Ce que le Mouvement citoyen propose :</h3>
                  <p>{section.objective}</p>
                </div>
              )}

              {/* Plusieurs objectifs */}
              {section.objectives && Array.isArray(section.objectives) && (
                <div class="objective-box" style={`background: ${colorSet.bg};`}>
                  <h3>Ce que le Mouvement citoyen propose :</h3>
                  {section.objectives.map((obj) => (
                    <p>{obj}</p>
                  ))}
                </div>
              )}

              {/* Actions / Comment ? */}
              {section.actions && section.actions.length > 0 && (
                <div class="actions-container">
                  <h3 style={`color: ${colorSet.accent};`}>Comment ?</h3>
                  <ul class="actions-list">
                    {section.actions.map((action, actionIndex) => (
                      <li style={`--bullet-color: ${colorSet.accent};`}>
                        <span class="action-number">{actionIndex + 1}</span>
                        {action}
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          );
        })}
      </section>

      <!-- Appel à contribution -->
      <section class="cta-section">
        <h2>Et vous ?</h2>
        <p>
          Ce programme est le fruit d'une réflexion collective. 
          Vos idées, vos suggestions et vos contributions sont les bienvenues !
        </p>
        <div class="cta-buttons">
          <a href="/#contact" class="cta-button primary">Nous contacter</a>
          <a href="/blog" class="cta-button secondary">Suivre les actualités</a>
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  .program-hero {
    background-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)),
      url('/assets/img/putange-derniere-reu.jpg');
    height: 50vh;
    min-height: 400px;
  }

  .download-section {
    margin: 3rem 0;
    overflow-x: hidden;
  }
  
  .download-section .document-card {
    max-width: 100%;
    box-sizing: border-box;
  }

  /* Synthèse des réunions publiques */
  .synthesis-section {
    margin: 2rem 0 3rem;
  }

  .synthesis-card {
    background: rgba(46, 139, 87, 0.05);
    border: 2px solid rgba(46, 139, 87, 0.2);
    border-radius: 1rem;
    padding: 2rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .synthesis-icon {
    font-size: 3rem;
    flex-shrink: 0;
  }

  .synthesis-content {
    flex: 1;
  }

  .synthesis-content h3 {
    font-family: var(--font-main);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--primary);
    margin: 0 0 0.75rem 0;
  }

  .synthesis-content p {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--secondary);
    margin: 0 0 1rem 0;
  }

  /* Introduction */
  .program-intro {
    text-align: center;
    margin: 3rem auto 4rem;
    max-width: 800px;
  }

  .program-intro h2 {
    font-family: var(--font-main);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: var(--secondary);
    margin-bottom: 1.5rem;
  }

  .program-intro p {
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    line-height: 1.7;
    color: var(--secondary);
    opacity: 0.85;
  }

  /* Sections du programme */
  .program-sections {
    margin: 3rem 0;
  }

  .program-section {
    position: relative;
    background: white;
    border-radius: 1.5rem;
    padding: 3rem 2.5rem 2.5rem;
    margin-bottom: 3rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
    border: none;
    overflow: visible;
  }

  .section-number {
    position: absolute;
    top: -20px;
    left: 2.5rem;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-main);
    font-size: 2rem;
    font-weight: 900;
    color: white;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.25);
    z-index: 1;
  }

  .section-title {
    font-family: var(--font-main);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    margin: 0.5rem 0 2rem 0;
    line-height: 1.2;
    letter-spacing: -0.5px;
  }

  /* Citations */
  .quotes-container {
    margin: 2rem 0 2.5rem;
    padding: 1.5rem 0;
    border-top: 2px solid #f0f0f0;
    border-bottom: 2px solid #f0f0f0;
  }

  .program-quote {
    font-style: italic;
    font-size: 1.05rem;
    line-height: 1.7;
    color: #444;
    margin: 0 0 1.25rem 0;
    padding: 1rem 1.5rem;
    border-left: 4px solid;
    background: rgba(0, 0, 0, 0.02);
    border-radius: 0 0.5rem 0.5rem 0;
  }

  .program-quote:last-child {
    margin-bottom: 0;
  }

  /* Objectif */
  .objective-box {
    padding: 2rem;
    border-radius: 1rem;
    margin: 2.5rem 0;
    color: white;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
  }

  .objective-box h3 {
    font-family: var(--font-main);
    font-size: 1.3rem;
    font-weight: 700;
    color: white;
    margin: 0 0 1.25rem 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .objective-box p {
    font-size: 1.15rem;
    line-height: 1.8;
    color: white;
    margin: 0 0 1rem 0;
    font-weight: 500;
  }

  .objective-box p:last-child {
    margin-bottom: 0;
  }

  /* Actions */
  .actions-container {
    margin: 2.5rem 0 0;
    background: linear-gradient(to right, rgba(46, 139, 87, 0.03) 0%, transparent 100%);
    padding: 2rem 1.5rem;
    border-radius: 1rem;
  }

  .actions-container h3 {
    font-family: var(--font-main);
    font-size: 1.4rem;
    font-weight: 700;
    margin: 0 0 1.5rem 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .actions-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .actions-list li {
    position: relative;
    padding-left: 3.5rem;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--secondary);
    background: white;
    padding: 1.25rem 1.25rem 1.25rem 4rem;
    border-radius: 0.75rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    transition: all 0.3s ease;
  }

  .actions-list li:hover {
    transform: translateX(8px);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  }

  .action-number {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    width: 36px;
    height: 36px;
    background: var(--bullet-color);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    font-family: var(--font-main);
  }

  /* Section CTA */
  .cta-section {
    text-align: center;
    margin: 4rem 0;
    padding: 3rem 2rem;
    background: rgba(46, 139, 87, 0.05);
    border-radius: 1rem;
    max-width: 100%;
    box-sizing: border-box;
  }

  .cta-section h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: var(--primary);
    margin-bottom: 1rem;
  }

  .cta-section p {
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    color: var(--secondary);
    margin-bottom: 2rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    padding: 1rem 2rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-family: var(--font-main);
    font-weight: 600;
    font-size: clamp(1rem, 2vw, 1.1rem);
    transition: all 0.2s ease;
    box-sizing: border-box;
    max-width: 100%;
  }

  .cta-button.primary {
    background-color: var(--primary);
    color: white;
  }

  .cta-button.primary:hover {
    background-color: var(--primary-dark);
    transform: translateY(-2px);
  }

  .cta-button.secondary {
    background-color: transparent;
    color: var(--primary);
    border: 2px solid var(--primary);
  }

  .cta-button.secondary:hover {
    background-color: var(--primary);
    color: white;
    transform: translateY(-2px);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .synthesis-card {
      flex-direction: column;
      padding: 1.5rem;
      text-align: center;
    }

    .synthesis-icon {
      font-size: 2.5rem;
    }

    .synthesis-content h3 {
      font-size: 1.2rem;
    }

    .synthesis-content p {
      font-size: 1rem;
    }

    .program-section {
      padding: 2.5rem 1.5rem 1.5rem;
      margin-bottom: 2.5rem;
    }

    .section-number {
      width: 50px;
      height: 50px;
      font-size: 1.5rem;
      top: -15px;
      left: 1.5rem;
    }

    .section-title {
      margin-bottom: 1.5rem;
      font-size: 1.5rem;
    }

    .quotes-container {
      padding: 1rem 0;
    }

    .program-quote {
      font-size: 0.95rem;
      padding: 0.75rem 1rem;
    }

    .objective-box {
      padding: 1.5rem;
    }

    .objective-box h3 {
      font-size: 1.1rem;
    }

    .objective-box p {
      font-size: 1rem;
    }

    .actions-container {
      padding: 1.5rem 1rem;
    }

    .actions-container h3 {
      font-size: 1.2rem;
    }

    .actions-list {
      gap: 1rem;
    }

    .actions-list li {
      font-size: 0.95rem;
      padding: 1rem 1rem 1rem 3.5rem;
    }

    .action-number {
      width: 32px;
      height: 32px;
      font-size: 0.9rem;
      left: 0.75rem;
    }

    .cta-section {
      padding: 2rem 1rem;
    }

    .cta-buttons {
      flex-direction: column;
    }

    .cta-button {
      width: 100%;
      justify-content: center;
    }
  }
</style>
