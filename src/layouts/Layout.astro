---
interface Props {
  title: string;
}

import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.svelte";
import "../styles/global.css";
import "../styles/articles.css";

const { title } = Astro.props;
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content="MCC Putanges-le-Lac" />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:site_name" content="MCC Putanges-le-Lac" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <!-- <meta property="og:image" content="/assets/img/" /> -->
    <meta property="og:image:alt" content="MCC Putanges-le-Lac" />
    <meta property="og:locale" content="fr" />
    <meta property="og:description" content="MCC Putanges-le-Lac" />

    <!-- Favicons -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/android-chrome-192x192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/android-chrome-512x512.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body>
    <Navbar currentPath={Astro.url.pathname} client:load />
    
    <!-- Bandeau informatif municipal -->
    <div class="municipal-notice">
      <div class="municipal-notice-content">
        <span class="notice-icon">ℹ️</span>
        <p>
          Information : En attendant la reprise en main du site officiel de la mairie, 
          nous publions ici les informations municipales essentielles.
        </p>
      </div>
    </div>
    
    <slot />
    <Footer />
  </body>
</html>

<style is:global>
  html, body {
    margin: 0;
    padding: 0;
  }

  .municipal-notice {
    background: #fffbeb;
    border-bottom: 2px solid #fbbf24;
    padding: 0.75rem 1rem;
  }

  .municipal-notice-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .notice-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .municipal-notice p {
    margin: 0;
    font-size: 0.95rem;
    color: #78350f;
    line-height: 1.4;
    font-family: var(--font-main);
  }

  @media (max-width: 768px) {
    .municipal-notice {
      padding: 0.65rem 1rem;
    }

    .municipal-notice-content {
      gap: 0.5rem;
    }

    .notice-icon {
      font-size: 1.1rem;
    }

    .municipal-notice p {
      font-size: 0.85rem;
    }
  }
</style>
